		"jsonwebtoken": "^9.0.2",
		"node-cron": "^3.0.3",
		"pg": "^8.13.3",
		"pg-hstore": "^2.3.4",
		"sequelize": "^6.37.5"
	},
	"devDependencies": {
		"eslint": "^9.17.0",
		"jest": "^29.7.0",
		"nodemon": "^3.1.9",
		"sequelize-cli": "^6.6.2",
		"supertest": "^7.0.0"
	},
	"jest": {
